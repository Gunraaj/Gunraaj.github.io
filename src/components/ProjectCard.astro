---
import type { Project } from '../content/site';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="relative group flex flex-col h-full tilt-card-parent perspective-[1000px]">
  <div class="absolute -inset-[1px] bg-gradient-to-r from-primary/50 to-accent/50 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-xl pointer-events-none"></div>
  <div class="relative items-start justify-between flex-1 flex flex-col bg-surface/40 backdrop-blur-2xl rounded-2xl border border-card-border/20 shadow-[inset_0_1px_1px_rgba(255,255,255,0.1)] p-6 sm:p-8 transition-transform duration-200 ease-out transform-gpu tilt-card-inner">
    <div class="flex items-start justify-between mb-6 w-full">
      <h3 class="text-2xl font-display font-medium text-heading group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-heading group-hover:to-primary transition-all">
        {project.title}
      </h3>
      {project.featured && (
        <span class="px-2 py-1 text-xs font-semibold bg-primary/20 text-primary rounded-full border border-primary/30">
          Featured
        </span>
      )}
    </div>
    
    <div class="flex flex-wrap gap-2 mb-4">
      {project.domainTags.map((tag) => (
        <span class="px-2 py-1 text-xs font-medium bg-background text-text rounded border border-border">
          {tag}
        </span>
      ))}
    </div>
    
    <p class="text-muted text-sm mb-6 flex-grow">
      {project.shortDescription}
    </p>
    
    {project.highlights.length > 0 && (
      <ul class="space-y-1 mb-6">
        {project.highlights.slice(0, 3).map((highlight) => (
          <li class="text-sm text-text flex items-start">
            <span class="text-primary mr-2">•</span>
            <span>{highlight}</span>
          </li>
        ))}
      </ul>
    )}

    <div class="mt-auto pt-4 border-t border-border flex gap-4">
      {project.links.map((link) => (
        <a
          href={link.url}
          target={link.url.startsWith('http') ? "_blank" : "_self"}
          rel={link.url.startsWith('http') ? "noopener noreferrer" : ""}
          class="text-sm font-medium text-primary hover:text-heading transition-colors flex items-center"
        >
          {link.label}
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      ))}
      <a
          href={`/projects/${project.id}`}
          class="text-sm font-medium text-muted hover:text-heading transition-colors ml-auto"
        >
          Details →
        </a>

    </div>
  </div>
</article>

<script>
  function initTilt() {
    document.querySelectorAll('.tilt-card-parent').forEach(parent => {
      const card = parent.querySelector('.tilt-card-inner') as HTMLElement;
      if (!card) return;

      parent.addEventListener('mousemove', (e: Event) => {
        const mouseEvent = e as MouseEvent;
        const rect = parent.getBoundingClientRect();
        const x = mouseEvent.clientX - rect.left - rect.width / 2;
        const y = mouseEvent.clientY - rect.top - rect.height / 2;
        
        // Calculate rotation based on cursor position (max 8 degrees)
        const xRotate = 8 * (-y / (rect.height / 2));
        const yRotate = 8 * (x / (rect.width / 2));
        
        card.style.transform = `perspective(1000px) rotateX(${xRotate}deg) rotateY(${yRotate}deg) scale3d(1.02, 1.02, 1.02)`;
      });
      
      parent.addEventListener('mouseleave', () => {
        card.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
      });
    });
  }
  
  initTilt();
  // Support Astro View Transitions if enabled later
  document.addEventListener('astro:page-load', initTilt);
</script>
