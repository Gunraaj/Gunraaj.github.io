---
import type { Project } from '../content/site';

interface Props {
  project: Project;
}

const { project } = Astro.props;

const bgIcons = {
  "vibration-analysis-system": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>`,
  "pm-bldc-motor-control": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/><line x1="12" x2="12" y1="2" y2="9"/><line x1="12" x2="12" y1="15" y2="22"/><line x1="2" x2="9" y1="12" y2="12"/><line x1="15" x2="22" y1="12" y2="12"/></svg>`,
  "kairo-ai-productivity": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"></path></svg>`,
  "synchronous-buck-converter": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>`,
  "design-direction-anirveda": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.58 7.58"/><circle cx="11" cy="11" r="2"/></svg>`,
  "ecopoints-sustainability": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>`,
  "pmsm-temp-control": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/><path d="M11.5 10v6"/><path d="M11.5 16h.01"/></svg>`
};

const defaultIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>`;
const bgIcon = bgIcons[project.id as keyof typeof bgIcons] || defaultIcon;
---

<article class="project-card relative group flex flex-col h-full tilt-card-parent perspective-[1000px]">
  <div class="relative items-start justify-between flex-1 flex flex-col bg-surface/20 hover:bg-surface/40 backdrop-blur-md rounded-2xl border border-border/40 hover:border-primary/30 p-6 sm:p-8 transition-all duration-300 ease-out transform-gpu tilt-card-inner overflow-hidden">
    
    <!-- Hover Gradient -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none z-0"></div>

    <!-- Background Artifact -->
    <div class="absolute -right-16 -bottom-16 w-64 h-64 text-text/[0.03] group-hover:text-primary/[0.05] transition-colors duration-700 pointer-events-none z-0 -rotate-12 group-hover:rotate-0 group-hover:scale-110">
      <Fragment set:html={bgIcon} />
    </div>

    <!-- Content (z-10) -->
    <div class="relative z-10 w-full flex flex-col h-full">
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-6 w-full gap-4">
      <h3 class="text-2xl font-display font-medium text-heading group-hover:text-primary transition-colors">
        {project.title}
      </h3>
      {project.featured && (
        <span class="px-2 py-1 text-[10px] font-mono tracking-widest uppercase bg-primary/5 text-primary rounded border border-primary/20 whitespace-nowrap">
          Featured
        </span>
      )}
    </div>
    
    <div class="flex flex-wrap gap-2 mb-6">
      {project.domainTags.map((tag) => (
        <span class="px-2 py-1 text-[10px] font-mono text-muted uppercase tracking-widest border border-border/40 bg-surface/50 rounded">
          {tag}
        </span>
      ))}
    </div>
    
    <p class="text-sm text-text/80 leading-relaxed mb-8 flex-grow">
      {project.shortDescription}
    </p>
    
    {project.highlights.length > 0 && (
      <ul class="space-y-2 mb-8 border-l border-primary/20 pl-3">
        {project.highlights.slice(0, 3).map((highlight) => (
          <li class="text-xs text-text/70 leading-relaxed flex items-start gap-2">
            <span class="text-primary/40 select-none">✦</span>
            <span>{highlight}</span>
          </li>
        ))}
      </ul>
    )}

    <div class="mt-auto pt-5 w-full border-t border-border/40 flex items-center justify-between">
      <div class="flex gap-4">
        {project.links.map((link) => (
          <a
            href={link.url}
            target={link.url.startsWith('http') ? "_blank" : "_self"}
            rel={link.url.startsWith('http') ? "noopener noreferrer" : ""}
            class="text-xs font-mono tracking-widest uppercase text-heading hover:text-primary transition-colors flex items-center gap-1"
          >
            {link.label}
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        ))}
      </div>
    </div>
    </div>
  </div>
</article>

<script>
  function initTilt() {
    document.querySelectorAll('.tilt-card-parent').forEach(parent => {
      const card = parent.querySelector('.tilt-card-inner') as HTMLElement;
      if (!card) return;

      parent.addEventListener('mousemove', (e: Event) => {
        const mouseEvent = e as MouseEvent;
        const rect = parent.getBoundingClientRect();
        const x = mouseEvent.clientX - rect.left - rect.width / 2;
        const y = mouseEvent.clientY - rect.top - rect.height / 2;
        
        const xRotate = 4 * (-y / (rect.height / 2));
        const yRotate = 4 * (x / (rect.width / 2));
        
        card.style.transform = `perspective(1000px) rotateX(${xRotate}deg) rotateY(${yRotate}deg) scale3d(1.01, 1.01, 1.01)`;
      });
      
      parent.addEventListener('mouseleave', () => {
        card.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
      });
    });
  }
  
  initTilt();
  document.addEventListener('astro:page-load', initTilt);
</script>
