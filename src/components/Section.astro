---
interface Props {
  title?: string;
  id?: string;
  class?: string;
}

const { title, id, class: className } = Astro.props;
---

<section id={id} class:list={["py-24 scroll-mt-32 scroll-reveal", className]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {title && (
      <div class="flex flex-col items-center justify-center mb-16 relative">
        <h2 class="text-3xl md:text-5xl font-display font-bold text-heading relative z-10 text-center">
          {title}
        </h2>
        <div class="absolute w-32 h-8 bg-primary/30 rounded-full blur-xl -z-10"></div>
        <div class="mt-4 w-12 h-1 bg-gradient-to-r from-transparent via-primary to-transparent rounded-full opacity-50"></div>
      </div>
    )}
    <slot />
  </div>
</section>
