---
import { siteConfig } from "../content/site";
---

<div class="max-w-5xl mx-auto space-y-16">
  <!-- Job Profile -->
  <div>
    <h3 class="text-xl font-display font-semibold text-heading mb-5 flex items-center gap-2">
      <span class="w-6 h-6 rounded bg-primary/10 flex items-center justify-center text-primary text-xs">💼</span>
      Job Profile
    </h3>
    <div class="bento-card">
      <p class="text-text/80 leading-relaxed">{siteConfig.resume.jobProfile}</p>
    </div>
  </div>

  <!-- Work Experience — Diamond timeline (MOVED TO START) -->
  <div>
    <h3 class="text-xl font-display font-semibold text-heading mb-6 flex items-center gap-2">
      <span class="w-6 h-6 rounded bg-primary/10 flex items-center justify-center text-primary text-xs">🏢</span>
      Work Experience
    </h3>
    <div class="relative border-l-2 border-primary/20 ml-3 space-y-6 pb-8">
      <!-- Ambient fade-out line -->
      <div class="absolute bottom-0 -left-[2px] w-[2px] h-24 bg-gradient-to-t from-background to-transparent z-10"></div>
      {siteConfig.resume.workExperience.map((exp) => (
        <div class="relative pl-8 group">
          <!-- Diamond node -->
          <div class="absolute -left-[7px] top-2 w-3 h-3 bg-primary border-2 border-background rotate-45 z-10" style="box-shadow: 0 0 0 3px rgb(var(--color-primary) / 0.15);"></div>
          <div class="glass-card p-5 hover:-translate-y-1 transition-transform duration-300">
            <div class="flex flex-wrap items-center gap-2 mb-1.5">
              <h4 class="text-sm font-display font-semibold text-heading group-hover:text-primary transition-colors">{exp.title}</h4>
              <span class="text-[10px] font-mono text-muted">{exp.period}</span>
            </div>
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xs text-muted font-medium">{exp.organization}</span>
              <span class="accent-chip text-[10px] py-0 border-primary/30">{exp.type}</span>
            </div>
            <ul class="space-y-1">
              {exp.details.map((d) => (
                <li class="text-xs text-text/70 flex items-start gap-2">
                  <span class="text-primary/40 mt-0.5 text-[10px]">▸</span>
                  <span class="leading-relaxed">{d}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Education Timeline -->
  <div>
    <h3 class="text-xl font-display font-semibold text-heading mb-6 flex items-center gap-2">
      <span class="w-6 h-6 rounded bg-accent/10 flex items-center justify-center text-accent text-xs">🎓</span>
      Education
    </h3>
    <div class="relative border-l-2 border-accent/20 ml-3 space-y-8 pb-8">
      <!-- Ambient fade-out line -->
      <div class="absolute bottom-0 -left-[2px] w-[2px] h-24 bg-gradient-to-t from-background to-transparent z-10"></div>
      {siteConfig.resume.education.map((edu) => (
        <div class="relative pl-8 group">
          <!-- Diamond node -->
          <div class="absolute -left-[7px] top-2 w-3 h-3 bg-accent border-2 border-background rotate-45 z-10" style="box-shadow: 0 0 0 3px rgb(var(--color-accent) / 0.15);"></div>
          <div class="glass-card p-5 hover:-translate-y-1 transition-transform duration-300">
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <span class="text-[10px] font-mono uppercase tracking-widest text-accent border border-accent/20 bg-accent/10 px-2 py-0.5 rounded-full">{edu.period}</span>
            </div>
            <h4 class="text-base font-display font-semibold text-heading mb-0.5">{edu.degree}</h4>
            <p class="text-xs text-muted mb-3 font-medium">{edu.institution}</p>
            <ul class="space-y-1.5">
              {edu.details.map((d) => (
                <li class="text-xs text-text/70 flex items-start gap-2">
                  <span class="text-accent/40 mt-0.5 text-[10px]">▸</span>
                  <span class="leading-relaxed">{d}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Specialization — Horizontal chips instead of stacked cards -->
  <div>
    <h3 class="text-xl font-display font-semibold text-heading mb-5 flex items-center gap-2">
      <span class="w-6 h-6 rounded bg-primary/10 flex items-center justify-center text-primary text-xs">🔬</span>
      Specialization
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      {siteConfig.resume.specialization.map((spec) => {
        const [title, ...rest] = spec.split(' — ');
        const desc = rest.join(' — ');
        return (
          <div class="glass-card p-4 group border-transparent hover:border-primary/20 transition-all duration-300 hover:shadow-[0_4px_20px_rgba(var(--color-primary)/0.05)]">
            <h4 class="text-sm font-semibold text-heading group-hover:text-primary transition-colors mb-1">{title}</h4>
            <p class="text-xs text-muted leading-relaxed">{desc}</p>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Areas of Interest + Hobbies — Side by side -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <div>
      <h3 class="text-xl font-display font-semibold text-heading mb-5 flex items-center gap-2">
        <span class="w-6 h-6 rounded bg-accent/10 flex items-center justify-center text-accent text-xs">🎯</span>
        Areas of Interest
      </h3>
      <div class="flex flex-wrap gap-2">
        {siteConfig.resume.areasOfInterest.map((area) => (
          <span class="text-xs font-mono text-accent border border-accent/20 bg-accent/5 px-3 py-1.5 rounded-full hover:bg-accent/10 hover:border-accent/40 transition-colors cursor-default">{area}</span>
        ))}
      </div>
    </div>
    <div>
      <h3 class="text-xl font-display font-semibold text-heading mb-5 flex items-center gap-2">
        <span class="w-6 h-6 rounded bg-warning/10 flex items-center justify-center text-warning text-xs">⚡</span>
        Hobbies & Interests
      </h3>
      <div class="grid grid-cols-3 gap-2">
        {siteConfig.resume.hobbies.map((hobby) => (
          <div class="glass-card p-3 text-center group hover:-translate-y-1 transition-all">
            <span class="text-xl mb-1 block group-hover:scale-110 transition-transform">{hobby.icon}</span>
            <span class="text-[10px] text-muted group-hover:text-heading transition-colors font-medium relative top-1">{hobby.name}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Certifications & Awards — Side by side -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <div>
      <h3 class="text-xl font-display font-semibold text-heading mb-5 flex items-center gap-2">
        <span class="w-6 h-6 rounded bg-primary/10 flex items-center justify-center text-primary text-xs">📜</span>
        Certifications
      </h3>
      <div class="space-y-2">
        {siteConfig.resume.certifications.map((cert) => (
          <div class="glass-card p-3.5 flex items-center justify-between group">
            <div>
              <h4 class="text-xs font-semibold text-heading group-hover:text-primary transition-colors">{cert.title}</h4>
              <p class="text-[10px] text-muted">{cert.issuer}</p>
            </div>
            <span class="text-[10px] font-mono text-primary/60 border border-primary/10 bg-primary/5 px-2 rounded">{cert.year}</span>
          </div>
        ))}
      </div>
    </div>
    <div>
      <h3 class="text-xl font-display font-semibold text-heading mb-5 flex items-center gap-2">
        <span class="w-6 h-6 rounded bg-accent/10 flex items-center justify-center text-accent text-xs">🏆</span>
        Awards & Honors
      </h3>
      <div class="space-y-2">
        {siteConfig.resume.awards.map((award) => (
          <div class="glass-card p-3.5 group">
            <h4 class="text-xs font-semibold text-heading group-hover:text-accent transition-colors">{award.title}</h4>
            <p class="text-[10px] text-muted mt-0.5">{award.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Co-Curricular & Volunteer -->
  <div>
    <h3 class="text-xl font-display font-semibold text-heading mb-5 flex items-center gap-2">
      <span class="w-6 h-6 rounded bg-primary/10 flex items-center justify-center text-primary text-xs">🤝</span>
      Co-Curricular & Volunteer Experience
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      {siteConfig.resume.coCurricular.map((item) => (
        <div class="glass-card p-4 group group">
          <h4 class="text-xs font-semibold text-heading group-hover:text-primary transition-colors mb-1.5">{item.activity}</h4>
          <p class="text-[11px] text-muted leading-relaxed">{item.description}</p>
        </div>
      ))}
      {siteConfig.resume.volunteerExperience.map((item) => (
        <div class="glass-card p-4 group">
          <h4 class="text-xs font-semibold text-heading group-hover:text-accent transition-colors mb-0.5">{item.role}</h4>
          <p class="text-[10px] font-mono text-muted uppercase tracking-widest mb-1.5">{item.org}</p>
          <p class="text-[11px] text-muted leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</div>
