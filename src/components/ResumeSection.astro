---
import { siteConfig } from "../content/site";
---

<div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24">
  <!-- Left Column: Work & Education -->
  <div class="lg:col-span-7 space-y-16">
    
    <!-- Job Profile -->
    <div>
      <p class="text-sm text-text/80 leading-relaxed font-medium italic border-l-2 border-primary/30 pl-4 py-1">
        {siteConfig.resume.jobProfile}
      </p>
    </div>

    <!-- Work Experience -->
    <div>
      <h3 class="text-xs font-mono text-muted uppercase tracking-widest mb-8 pb-4 border-b border-border/40">Work Experience</h3>
      <div class="space-y-10 relative">
        <div class="absolute left-[3px] top-2 bottom-0 w-[1px] bg-gradient-to-b from-border to-transparent"></div>
        {siteConfig.resume.workExperience.map((exp) => (
          <div class="relative pl-8 group">
            <div class="absolute left-0 top-1.5 w-[7px] h-[7px] rounded-full bg-background border border-primary group-hover:bg-primary transition-colors"></div>
            <div class="mb-1.5 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
              <h4 class="text-lg font-display font-medium text-heading group-hover:text-primary transition-colors">{exp.title}</h4>
              <span class="text-xs font-mono text-muted">{exp.period}</span>
            </div>
            <div class="mb-4">
              <span class="text-sm font-medium text-text/90">{exp.organization}</span>
              <span class="mx-2 text-muted">—</span>
              <span class="text-xs text-muted">{exp.type}</span>
            </div>
            <ul class="space-y-2">
              {exp.details.map((d) => (
                <li class="text-xs text-text/70 leading-relaxed flex gap-3">
                  <span class="text-primary/40 mt-1 select-none">✦</span>
                  <span>{d}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <!-- Education -->
    <div>
      <h3 class="text-xs font-mono text-muted uppercase tracking-widest mb-8 pb-4 border-b border-border/40">Education</h3>
      <div class="space-y-10 relative">
        <div class="absolute left-[3px] top-2 bottom-0 w-[1px] bg-gradient-to-b from-border to-transparent"></div>
        {siteConfig.resume.education.map((edu) => (
          <div class="relative pl-8 group">
            <div class="absolute left-0 top-1.5 w-[7px] h-[7px] rounded-full bg-background border border-accent group-hover:bg-accent transition-colors"></div>
            <div class="mb-1.5 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
              <h4 class="text-lg font-display font-medium text-heading group-hover:text-accent transition-colors">{edu.degree}</h4>
              <span class="text-xs font-mono text-muted">{edu.period}</span>
            </div>
            <div class="mb-4">
              <span class="text-sm font-medium text-text/90">{edu.institution}</span>
            </div>
            <ul class="space-y-2">
              {edu.details.map((d) => (
                <li class="text-xs text-text/70 leading-relaxed flex gap-3">
                  <span class="text-accent/40 mt-1 select-none">✦</span>
                  <span>{d}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Right Column: Extracurriculars & Meta -->
  <div class="lg:col-span-5 space-y-16">
    
    <!-- Specialization -->
    <div>
      <h3 class="text-xs font-mono text-muted uppercase tracking-widest mb-8 pb-4 border-b border-border/40">Specialization</h3>
      <div class="space-y-6">
        {siteConfig.resume.specialization.map((spec) => {
          const [title, ...rest] = spec.split(' — ');
          const desc = rest.join(' — ');
          return (
            <div class="group">
              <h4 class="text-base font-display font-medium text-heading group-hover:text-primary transition-colors mb-1">{title}</h4>
              <p class="text-xs text-muted leading-relaxed">{desc}</p>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Co-Curricular & Volunteer -->
    <div>
      <h3 class="text-xs font-mono text-muted uppercase tracking-widest mb-8 pb-4 border-b border-border/40">Leadership & Engagement</h3>
      <div class="space-y-8">
        {siteConfig.resume.coCurricular.map((item) => (
          <div class="group">
            <h4 class="text-sm font-semibold text-heading group-hover:text-primary transition-colors mb-1">{item.activity}</h4>
            <p class="text-[11px] text-muted leading-relaxed">{item.description}</p>
          </div>
        ))}
        {siteConfig.resume.volunteerExperience.map((item) => (
          <div class="group">
            <h4 class="text-sm font-semibold text-heading group-hover:text-accent transition-colors mb-0.5">{item.role}</h4>
            <p class="text-[10px] font-mono text-muted uppercase tracking-widest mb-1.5">{item.org}</p>
            <p class="text-[11px] text-muted leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Certifications -->
    <div>
      <h3 class="text-xs font-mono text-muted uppercase tracking-widest mb-8 pb-4 border-b border-border/40">Certifications</h3>
      <div class="space-y-5">
        {siteConfig.resume.certifications.map((cert) => (
          <div class="group flex items-start justify-between gap-4">
            <div>
              <h4 class="text-sm font-medium text-heading group-hover:text-primary transition-colors">{cert.title}</h4>
              <p class="text-[10px] text-muted mt-0.5">{cert.issuer}</p>
            </div>
            <span class="text-[10px] font-mono text-muted whitespace-nowrap">{cert.year}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Awards -->
    <div>
      <h3 class="text-xs font-mono text-muted uppercase tracking-widest mb-8 pb-4 border-b border-border/40">Awards & Honors</h3>
      <div class="space-y-5">
        {siteConfig.resume.awards.map((award) => (
          <div class="group">
            <h4 class="text-sm font-medium text-heading group-hover:text-accent transition-colors">{award.title}</h4>
            <p class="text-xs text-muted mt-1 leading-relaxed">{award.description}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</div>
