---
import { siteConfig } from "../content/site";
---

<div class="space-y-16">
  <!-- ═══ SHORT TERM: Horizontal scroll timeline ═══ -->
  <div>
    <div class="flex items-center justify-between mb-6">
      <h3 class="text-xl font-display font-semibold text-heading flex items-center gap-2">
        <span class="w-6 h-6 rounded bg-primary/10 flex items-center justify-center text-primary text-xs">📋</span>
        Short-Term Goals
      </h3>
      <span class="text-xs font-mono text-muted">Next 1–2 years →</span>
    </div>
    
    <!-- Horizontal scrollable timeline -->
    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute top-6 left-0 right-0 h-px bg-gradient-to-r from-primary/40 via-primary/20 to-transparent z-0"></div>
      
      <div class="flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide" style="-webkit-overflow-scrolling: touch;">
        {siteConfig.futureAspirations.shortTerm.map((item, i) => (
          <div class="snap-start flex-shrink-0 w-72 sm:w-80 relative pt-10">
            <!-- Timeline dot -->
            <div class="absolute top-[18px] left-6 w-3 h-3 rounded-full bg-primary border-2 border-background z-10" style={`box-shadow: 0 0 0 3px rgb(var(--color-primary) / 0.15);`}></div>
            
            <div class="bento-card !p-5 h-full">
              <div class="flex items-center justify-between mb-3">
                <span class="accent-chip text-[10px]">{item.timeline}</span>
                <span class="text-xs font-mono text-muted/40 font-bold">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <h4 class="text-sm font-semibold text-heading mb-2">{item.goal}</h4>
              <p class="text-xs text-muted leading-relaxed">{item.strategy}</p>
            </div>
          </div>
        ))}
        <!-- Fade end indicator -->
        <div class="snap-start flex-shrink-0 w-16 flex items-center justify-center pt-10">
          <span class="text-muted/30 text-2xl">→</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ LONG TERM: Stacked cards with big numbers ═══ -->
  <div>
    <h3 class="text-xl font-display font-semibold text-heading mb-6 flex items-center gap-2">
      <span class="w-6 h-6 rounded bg-accent/10 flex items-center justify-center text-accent text-xs">🔭</span>
      Long-Term Vision
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {siteConfig.futureAspirations.longTerm.map((item, i) => (
        <div class="bento-card group">
          <span class="text-6xl font-display font-black text-primary/[0.05] absolute top-2 right-4 select-none pointer-events-none leading-none">
            {String(i + 1).padStart(2, '0')}
          </span>
          <h4 class="text-sm font-semibold text-heading group-hover:text-accent transition-colors mb-2 relative z-10">{item.goal}</h4>
          <p class="text-xs text-muted leading-relaxed relative z-10">{item.description}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- ═══ FURTHER STUDY & CONTINUOUS IMPROVEMENT ═══ -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
    <div class="glass-card p-5">
      <h3 class="text-base font-semibold text-heading mb-4 flex items-center gap-2">
        <span class="text-primary">📚</span> Topics for Further Study
      </h3>
      <div class="flex flex-wrap gap-2">
        {siteConfig.futureAspirations.furtherStudy.map((topic) => (
          <span class="accent-chip text-[11px] py-1">{topic}</span>
        ))}
      </div>
    </div>
    <div class="glass-card p-5">
      <h3 class="text-base font-semibold text-heading mb-4 flex items-center gap-2">
        <span class="text-accent">🔄</span> Continuous Improvement
      </h3>
      <ul class="space-y-2">
        {siteConfig.futureAspirations.continuousImprovement.map((strategy) => (
          <li class="flex items-start gap-2 text-sm text-text/80">
            <span class="text-accent/50 mt-0.5 text-xs">▸</span>
            <span>{strategy}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>

<style>
  /* Hide scrollbar for horizontal scroll */
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
