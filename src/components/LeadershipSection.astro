---
import { siteConfig } from "../content/site";
---

<div class="space-y-12">
  <!-- Role Progression — Asymmetric Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {siteConfig.experience.map((org, index) => (
      <div class="glass-card p-6 relative overflow-hidden group hover:border-primary/40 transition-all duration-300 flex flex-col justify-between">
        <!-- Big watermark number -->
        <div class="absolute -right-4 -bottom-8 text-8xl font-display font-bold text-primary/5 group-hover:-translate-y-4 transition-transform duration-700 pointer-events-none select-none z-0">
          {String(index + 1).padStart(2, '0')}
        </div>
        
        <div class="relative z-10 mb-6 border-b border-border/50 pb-4">
          <div class="flex items-center gap-3 mb-2">
            <span class="w-10 h-10 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center text-primary text-lg shadow-[0_0_15px_rgba(var(--color-primary)/0.2)]">⚡</span>
            <div>
              <h4 class="text-lg font-display font-bold text-heading group-hover:text-primary transition-colors">{org.org}</h4>
              <p class="text-[10px] font-mono text-muted uppercase tracking-wider">{org.location}</p>
            </div>
          </div>
        </div>

        <div class="relative z-10 space-y-5 flex-grow">
          {org.roles.map((role) => (
            <div class="group/role">
              <div class="flex flex-col gap-1 mb-2">
                <h5 class="text-sm font-semibold text-heading group-hover/role:text-accent transition-colors">{role.title}</h5>
                <div class="flex items-center gap-2">
                  <span class="text-[10px] font-mono text-muted bg-surface/50 px-2 py-0.5 rounded border border-border/50">{role.date}</span>
                  <span class="text-[10px] font-medium text-accent px-2 py-0.5 bg-accent/10 rounded border border-accent/20">{role.category}</span>
                </div>
              </div>
              <ul class="space-y-1.5 mt-2">
                {role.details.map((d) => (
                  <li class="text-xs text-text/80 flex items-start gap-2">
                    <span class="text-primary/60 mt-0.5 text-xs font-bold shrink-0">→</span>
                    <span class="leading-relaxed font-medium">{d}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <!-- Collaborative Case Studies — Bento style cards -->
  <div>
    <h3 class="text-2xl font-display font-semibold text-heading mb-8 flex items-center gap-3">
      <span class="w-8 h-8 rounded-lg bg-surface/50 border border-border flex items-center justify-center text-muted text-sm">💡</span>
      Case Studies in Collaboration
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {siteConfig.collaborativeExperiences.map((exp) => (
        <div class="bento-card group flex flex-col justify-between">
          <div>
            <h4 class="text-lg font-display font-bold text-heading mb-5 text-primary group-hover:text-accent transition-colors">{exp.title}</h4>
            
            <div class="space-y-5 mb-6 mt-4">
              <div class="pl-4 border-l-2 border-primary/40">
                <span class="text-[10px] font-mono uppercase tracking-wider text-muted block mb-1 font-bold">Context</span>
                <p class="text-xs text-text/80 leading-relaxed">{exp.context}</p>
              </div>
              
              <div class="pl-4 border-l-2 border-accent/40">
                <span class="text-[10px] font-mono uppercase tracking-wider text-muted block mb-1 font-bold">Role</span>
                <p class="text-xs text-text/80">{exp.role}</p>
              </div>
              
              <div class="pl-4 border-l-2 border-primary/40">
                <span class="text-[10px] font-mono uppercase tracking-wider text-muted block mb-1 font-bold">Team</span>
                <p class="text-xs text-text/80 leading-relaxed">{exp.teamDynamics}</p>
              </div>
            </div>
          </div>

          <div>
            {exp.conflictResolution && (
              <div class="bg-warning/5 border border-warning/20 rounded-xl p-4 mb-5 shadow-[inset_0_0_20px_rgba(var(--color-warning)/0.03)]">
                <span class="text-[10px] font-mono uppercase tracking-wider text-warning flex items-center gap-2 mb-1.5 font-bold">
                  <span class="text-sm">⚠</span> Conflict Resolution
                </span>
                <p class="text-xs text-text/80 leading-relaxed">{exp.conflictResolution}</p>
              </div>
            )}
            <div class="flex flex-wrap gap-2">
              {exp.achievements.map((a) => (
                <span class="text-[10px] font-mono text-primary bg-primary/5 px-2.5 py-1 rounded border border-primary/10">✓ {a}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
