---
import { siteConfig } from "../content/site";
---

<section
  id="hero"
  class="relative min-h-screen flex items-center bg-background overflow-hidden"
>
  <!-- Ambient gradient blobs -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-primary/8 rounded-full filter blur-[120px] -translate-y-1/4 translate-x-1/4"></div>
  <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-accent/6 rounded-full filter blur-[100px] translate-y-1/4 -translate-x-1/4"></div>
  
  <!-- Subtle dot pattern -->
  <div class="absolute inset-0 opacity-[0.03]">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,currentColor_1px,transparent_0)] bg-[size:32px_32px] text-heading"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 z-10 w-full py-32 sm:py-0">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-4 items-center">
      
      <!-- Left Column: Text — takes 7 cols for asymmetry -->
      <div class="lg:col-span-7 flex flex-col items-start">
        <!-- Small tagline -->
        <div class="inline-flex items-center gap-2 mb-6 animate-fade-in-up">
          <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
          <span id="typewriter-text" class="text-sm font-mono text-muted"></span>
          <span class="animate-blink text-primary text-sm">|</span>
        </div>

        <!-- Giant name — overlapping, bold -->
        <h1 class="text-6xl sm:text-7xl lg:text-[5.5rem] xl:text-[6.5rem] font-display font-bold tracking-tighter text-heading leading-[0.9] mb-4 animate-fade-in-up delay-100">
          {siteConfig.profile.name.split(' ')[0]}
          <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-primary to-accent">{siteConfig.profile.name.split(' ')[1]}</span>
        </h1>

        <!-- Role — with decorative line -->
        <div class="flex items-center gap-4 mb-6 animate-fade-in-up delay-200">
          <div class="h-px w-12 bg-gradient-to-r from-primary to-transparent"></div>
          <h2 class="text-lg sm:text-xl font-display font-medium text-heading/80">
            {siteConfig.profile.title}
          </h2>
        </div>

        <!-- Identity line -->
        <p class="text-base text-muted max-w-lg mb-8 leading-relaxed animate-fade-in-up delay-300">
          {siteConfig.profile.identityLine}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap gap-3 animate-fade-in-up delay-400">
          <a
            href={siteConfig.profile.social.resume}
            class="group px-6 py-3 bg-primary text-white hover:bg-primary/90 font-semibold rounded-lg transition-all hover:-translate-y-0.5 shadow-lg shadow-primary/20 flex items-center gap-2"
          >
            Download CV
            <svg class="w-4 h-4 group-hover:translate-y-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
          </a>
          <a
            href="#projects"
            class="px-6 py-3 bg-surface border border-border text-heading font-semibold rounded-lg transition-all hover:-translate-y-0.5 hover:border-primary/30"
          >
            View Projects
          </a>
        </div>

        <!-- Quick stats strip -->
        <div class="flex items-center gap-6 mt-10 pt-8 border-t border-border/40 animate-fade-in-up delay-400">
          <div>
            <span class="text-2xl font-display font-bold text-heading">4</span>
            <span class="block text-xs text-muted mt-0.5">Featured Projects</span>
          </div>
          <div class="w-px h-8 bg-border/40"></div>
          <div>
            <span class="text-2xl font-display font-bold text-heading">2+</span>
            <span class="block text-xs text-muted mt-0.5">Years Design Exp.</span>
          </div>
          <div class="w-px h-8 bg-border/40"></div>
          <div>
            <span class="text-2xl font-display font-bold text-heading">3</span>
            <span class="block text-xs text-muted mt-0.5">Leadership Roles</span>
          </div>
        </div>
      </div>

      <!-- Right Column: Photo — 5 cols, offset upward -->
      <div class="lg:col-span-5 flex justify-center lg:justify-end animate-fade-in-up delay-300">
        <div class="relative">
          <!-- Main photo container -->
          <div
            id="hero-avatar-container"
            class="relative w-72 h-72 sm:w-80 sm:h-80 lg:w-[360px] lg:h-[420px] rounded-2xl overflow-hidden group shadow-2xl"
          >
            <!-- Accent border glow -->
            <div class="absolute -inset-1 bg-gradient-to-br from-primary/40 via-transparent to-accent/30 rounded-2xl blur-sm opacity-60 group-hover:opacity-100 transition-opacity duration-500 -z-10"></div>
            
            <div class="absolute inset-0 bg-surface/30 backdrop-blur-sm rounded-2xl border border-border/40 overflow-hidden">
              <img
                src="/profile.jpg"
                alt={siteConfig.profile.name}
                class="w-full h-full object-cover object-[center_20%] transition-all duration-700"
                id="hero-avatar-img"
                loading="eager"
              />

            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce-slow">
    <span class="text-[10px] font-mono text-muted uppercase tracking-widest">Scroll</span>
    <svg class="w-4 h-4 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7"></path></svg>
  </div>
</section>

<style>
  .delay-100 { animation-delay: 100ms; }
  .delay-200 { animation-delay: 200ms; }
  .delay-300 { animation-delay: 300ms; }
  .delay-400 { animation-delay: 400ms; }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.7s ease-out forwards;
    opacity: 0;
  }
  @keyframes bounceSlow {
    0%, 100% { transform: translate(-50%, 0); }
    50% { transform: translate(-50%, 6px); }
  }
  .animate-bounce-slow {
    animation: bounceSlow 2s ease-in-out infinite;
  }
</style>

<script>
  // Typewriter
  function initTypewriter() {
    const el = document.getElementById("typewriter-text");
    if (!el || el.dataset.typed) return;
    el.dataset.typed = "true";
    const text = "Available for opportunities";
    let i = 0;
    el.textContent = "";
    const type = () => {
      if (i < text.length) {
        el.textContent += text.charAt(i);
        i++;
        setTimeout(type, 50);
      }
    };
    setTimeout(type, 1800);
  }
  initTypewriter();
  document.addEventListener("astro:page-load", initTypewriter);
</script>

<style>
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  .animate-blink {
    animation: blink 1s step-end infinite;
  }
</style>
