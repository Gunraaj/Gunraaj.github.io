---

<style>
  .ticker-wrapper {
    position: relative;
    width: 100vw;
    margin-left: 50%;
    transform: translateX(-50%);
    overflow: hidden;
    padding: 0.5rem 0;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    cursor: grab;
    user-select: none;
  }
  .ticker-wrapper:active {
    cursor: grabbing;
  }
  .ticker-wrapper.dragging .ticker-track {
    animation-play-state: paused !important;
  }
  
  .ticker-track {
    display: flex;
    width: max-content;
    gap: 1.5rem;
    animation: scroll 70s linear infinite;
  }
  
  .ticker-track:hover {
    animation-play-state: paused;
  }

  .ticker-track.reverse {
    animation-direction: reverse;
  }

  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 0.75rem)); } 
  }
</style>

<div class="flex flex-col gap-4 py-8">
  
  <!-- Technical Band -->
  <div class="ticker-wrapper" data-ticker>
    <div class="ticker-track">
      {doubleTechnical.map((skill) => (
        <div class="flex items-center gap-3 px-5 py-2.5 rounded-full border border-border/40 bg-surface/60 hover:bg-surface hover:border-primary/50 transition-colors group cursor-default whitespace-nowrap shadow-sm hover:shadow-[0_0_20px_rgba(34,197,94,0.15)]">
           <div class="w-6 h-6 rounded bg-background flex items-center justify-center border border-primary/30 text-primary group-hover:text-primary transition-colors shadow-[0_0_10px_rgba(34,197,94,0.2)]">
            <Fragment set:html={getTechIcon(skill.name)} />
          </div>
          <span class="text-sm font-display font-medium text-heading group-hover:text-primary transition-all duration-300 group-hover:[text-shadow:0_0_12px_rgba(34,197,94,0.6)]">{skill.name}</span>
          <span class="text-[10px] font-mono text-muted uppercase tracking-wider pl-3 ml-1 border-l border-border/60">{skill.details}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Creative Band -->
  <div class="ticker-wrapper" data-ticker>
    <div class="ticker-track reverse">
      {doubleCreative.map((skill) => (
        <div class="flex items-center gap-3 px-5 py-2.5 rounded-full border border-border/40 bg-surface/60 hover:bg-surface hover:border-primary/50 transition-colors group cursor-default whitespace-nowrap shadow-sm hover:shadow-[0_0_20px_rgba(34,197,94,0.15)]">
           <div class="w-6 h-6 rounded-full bg-background flex items-center justify-center border border-border/50 text-muted group-hover:text-primary transition-colors">
            <Fragment set:html={getCreativeIcon(skill.name)} />
          </div>
          <span class="text-sm font-display font-medium text-heading group-hover:text-primary transition-all duration-300 group-hover:[text-shadow:0_0_12px_rgba(34,197,94,0.6)]">{skill.name}</span>
          <span class="text-[10px] font-mono text-muted uppercase tracking-wider pl-3 ml-1 border-l border-border/60">{(skill as any).evidence}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Leadership Band -->
  <div class="ticker-wrapper" data-ticker>
    <div class="ticker-track">
      {doubleLeadership.map((skill) => (
        <div class="flex items-center gap-3 px-5 py-2.5 rounded-full border border-border/40 bg-surface/60 hover:bg-surface hover:border-primary/50 transition-colors group cursor-default whitespace-nowrap shadow-sm hover:shadow-[0_0_20px_rgba(34,197,94,0.15)]">
           <div class="w-6 h-6 flex items-center justify-center text-muted group-hover:text-primary transition-colors">
            <Fragment set:html={getLeadershipIcon(skill.name)} />
          </div>
          <span class="text-sm font-display font-medium text-heading group-hover:text-primary transition-all duration-300 group-hover:[text-shadow:0_0_12px_rgba(34,197,94,0.6)]">{skill.name}</span>
          <span class="text-[10px] font-mono text-muted uppercase tracking-wider pl-3 ml-1 border-l border-border/60">{(skill as any).evidence}</span>
        </div>
      ))}
    </div>
  </div>

</div>

<!-- Philosophy Section -->
<div class="mt-8 max-w-5xl mx-auto px-4 text-center">
  <p class="text-sm text-muted leading-relaxed font-mono">
    <span class="text-primary font-semibold">The Cognitive Core:</span> True engineering isn't just about syntax; it's about <span class="text-heading text-primary">systems-level adaptability</span> and cross-domain learning. Whether I am optimizing PI controllers for hardware motors or crafting psychological UI states in Figma, the underlying logic is identical. <span class="italic text-heading">For example:</span> Debugging a PCB trace uses the exact same rigorous analytical mindset as color grading a video in Premiere Pro—it's all about mastering the flow of signals, whether electrical or visual.
  </p>
</div>

<script>
  function initTickers() {
    document.querySelectorAll('[data-ticker]').forEach((wrapper) => {
      const track = wrapper.querySelector('.ticker-track') as HTMLElement;
      if (!track || (wrapper as any)._tickerInit) return;
      (wrapper as any)._tickerInit = true;

      let isDragging = false;
      let startX = 0;
      let scrollOffset = 0;
      let currentTranslate = 0;

      function getComputedTranslateX(el: HTMLElement): number {
        const style = window.getComputedStyle(el);
        const matrix = new DOMMatrix(style.transform);
        return matrix.m41;
      }

      function onPointerDown(e: PointerEvent) {
        isDragging = true;
        startX = e.clientX;
        currentTranslate = getComputedTranslateX(track);
        scrollOffset = currentTranslate;
        wrapper.classList.add('dragging');
        track.style.transform = `translateX(${currentTranslate}px)`;
        (wrapper as HTMLElement).setPointerCapture(e.pointerId);
      }

      function onPointerMove(e: PointerEvent) {
        if (!isDragging) return;
        const dx = e.clientX - startX;
        track.style.transform = `translateX(${scrollOffset + dx}px)`;
      }

      function onPointerUp() {
        if (!isDragging) return;
        isDragging = false;
        wrapper.classList.remove('dragging');
        // Resume animation from current position
        track.style.transform = '';
      }

      wrapper.addEventListener('pointerdown', onPointerDown as EventListener);
      wrapper.addEventListener('pointermove', onPointerMove as EventListener);
      wrapper.addEventListener('pointerup', onPointerUp as EventListener);
      wrapper.addEventListener('pointerleave', onPointerUp as EventListener);
    });
  }
  initTickers();
  document.addEventListener('astro:page-load', initTickers);
</script>
