---
import { siteConfig } from "../content/site";
---

<div class="max-w-5xl mx-auto">
  {siteConfig.testimonials.map((t, i) => (
    <div class:list={["scroll-reveal glass-card p-8 md:p-10 relative overflow-hidden group hover:border-primary/30 transition-all duration-500", i > 0 ? "mt-8" : ""]}>
      <!-- Decorative quote mark -->
      <div class="absolute top-4 right-6 text-8xl font-serif leading-none text-primary/[0.06] select-none pointer-events-none group-hover:text-primary/[0.12] transition-colors">"</div>

      <div class="flex items-start gap-6">
        <!-- Avatar with initials -->
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary to-accent flex items-center justify-center text-white font-serif font-bold text-lg flex-shrink-0 shadow-lg shadow-primary/20">
          {t.initials}
        </div>

        <div class="flex-1">
          <blockquote class="text-text/80 leading-relaxed text-lg md:text-xl mb-6 font-light italic relative">
            "{t.quote}"
          </blockquote>
          <div class="flex flex-wrap items-center gap-3">
            <span class="text-heading font-semibold text-sm">{t.name}</span>
            <span class="w-1 h-1 rounded-full bg-primary/30"></span>
            <span class="text-muted text-xs">{t.role}</span>
            <span class="w-1 h-1 rounded-full bg-primary/30"></span>
            <span class="text-primary/60 text-xs font-mono">{t.organization}</span>
          </div>
        </div>
      </div>
    </div>
  ))}
</div>
