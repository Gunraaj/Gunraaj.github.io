---
import { siteConfig } from "../content/site";

const { strengths, weaknesses, opportunities, threats } = siteConfig.swot;
---

<div class="max-w-5xl mx-auto">
  <!-- Asymmetric Bento Grid for SWOT -->
  <div class="grid grid-cols-1 md:grid-cols-12 gap-5 grid-rows-[auto]">
    
    <!-- Strengths (Large focal point, Top Left, span 7) -->
    <div class="md:col-span-7 glass-card p-8 relative overflow-hidden group hover:border-primary/40 transition-all duration-300">
      <div class="absolute -right-8 -top-8 text-9xl opacity-5 group-hover:opacity-10 group-hover:rotate-12 transition-all duration-500 text-primary">💪</div>
      <div class="relative z-10">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary border border-primary/20">S</div>
          <h3 class="text-2xl font-display font-semibold text-heading tracking-tight">Strengths</h3>
        </div>
        <ul class="space-y-4">
          {strengths.map((item, i) => (
            <li class="flex items-start gap-4">
              <span class="text-xs font-mono mt-1 text-primary/50 bg-primary/5 px-2 py-0.5 rounded border border-primary/10">{String(i + 1).padStart(2, '0')}</span>
              <span class="text-sm text-text/80 leading-relaxed font-medium group-hover:text-text transition-colors">{item.text}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Weaknesses (Smaller targeted panel, Top Right, span 5) -->
    <div class="md:col-span-5 glass-card p-8 relative overflow-hidden group border-warning/10 hover:border-warning/30 bg-warning/[0.02] transition-all duration-300">
      <div class="absolute -right-6 -bottom-6 text-8xl opacity-5 group-hover:opacity-10 group-hover:-rotate-12 transition-all duration-500 text-warning">🎯</div>
      <div class="relative z-10">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-warning/10 flex items-center justify-center text-warning border border-warning/20">W</div>
          <h3 class="text-2xl font-display font-semibold text-heading tracking-tight">Weaknesses</h3>
        </div>
        <ul class="space-y-4">
          {weaknesses.map((item, i) => (
            <li class="flex items-start gap-3">
              <span class="text-warning/50 mt-1 flex-shrink-0">⤬</span>
              <span class="text-sm text-text/70 leading-relaxed">{item.text}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Threats (Bottom Left, span 5) -->
    <div class="md:col-span-5 glass-card p-8 relative overflow-hidden group border-red-500/10 hover:border-red-500/30 bg-red-500/[0.02] transition-all duration-300">
      <div class="absolute -left-6 -bottom-6 text-8xl opacity-5 group-hover:opacity-10 transition-all duration-500 text-red-500">⚡</div>
      <div class="relative z-10">
         <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-red-500/10 flex items-center justify-center text-red-500 border border-red-500/20">T</div>
          <h3 class="text-2xl font-display font-semibold text-heading tracking-tight">Threats & Risks</h3>
        </div>
        <ul class="space-y-4">
          {threats.map((item, i) => (
            <li class="flex items-start gap-3">
              <span class="text-red-500/50 mt-1 flex-shrink-0">!</span>
              <span class="text-sm text-text/70 leading-relaxed group-hover:text-text/90 transition-colors">{item.text}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Opportunities (Large focal point, Bottom Right, span 7) -->
    <div class="md:col-span-7 glass-card p-8 relative overflow-hidden group hover:border-accent/40 bg-gradient-to-br from-transparent to-accent/[0.02] transition-all duration-300">
      <div class="absolute right-0 bottom-0 text-9xl opacity-5 group-hover:opacity-10 group-hover:scale-110 group-hover:-translate-y-2 transition-all duration-700 text-accent origin-bottom-right">🚀</div>
      <div class="relative z-10">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center text-accent border border-accent/20">O</div>
          <h3 class="text-2xl font-display font-semibold text-heading tracking-tight">Opportunities</h3>
        </div>
        <ul class="space-y-4">
           {opportunities.map((item, i) => (
             <li class="flex items-start gap-4">
               <span class="text-xs font-mono mt-1 text-accent border border-accent/20 bg-accent/10 w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0">✓</span>
               <span class="text-sm text-text/80 leading-relaxed font-medium group-hover:text-text transition-colors">{item.text}</span>
             </li>
           ))}
        </ul>
      </div>
    </div>

  </div>
</div>
