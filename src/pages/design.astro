---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import { siteConfig } from '../content/site';

const itemClasses = "aspect-square bg-gray-900 rounded-lg border border-gray-800 hover:border-primary transition-all flex items-center justify-center text-gray-500 font-medium p-4 text-center cursor-pointer hover:bg-gray-800";
---

<Layout title="Design & Media">
  <Section title="Design & Media" class="pt-24 min-h-screen">
    <div class="space-y-16">
      {siteConfig.design.map((category) => (
        <div>
          <h3 class="text-2xl font-bold text-white mb-8 pl-4 border-l-4 border-accent">
            {category.category}
          </h3>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            {category.items.map((item) => (
              <div class={itemClasses}>
                <span class="text-gray-300 group-hover:text-white transition-colors">
                  {item}
                </span>
              </div>
            ))}
          </div>
        </div>
      ))}
      
      <div class="mt-16 bg-surface p-8 rounded-xl border border-gray-800">
        <h3 class="text-2xl font-bold text-white mb-4">Design Philosophy</h3>
        <p class="text-gray-300 italic text-lg border-l-4 border-gray-600 pl-4 py-2">
          "I design not just for aesthetics, but for clarity, intent, and communication."
        </p>
      </div>
    </div>
  </Section>
</Layout>
