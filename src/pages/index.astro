---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SkillMatrix from "../components/SkillMatrix.astro";
import { siteConfig } from "../content/site";

const featuredProjects = siteConfig.projects.filter(
  (p) => p.featured && p.enabled,
);
---

<Layout title="Home" showPreloader={true}>
  <Hero />

  <Section id="about" class="bg-surface">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
      <div class="lg:col-span-5">
        <span
          class="text-[10px] font-mono uppercase tracking-[0.3em] text-primary mb-4 block"
          >01 — About</span
        >
        <h2
          class="text-4xl md:text-5xl font-serif italic text-heading leading-tight mb-6"
        >
          Who I Am
        </h2>
        <div class="w-16 h-0.5 bg-primary/30 mb-6"></div>
        <p
          class="text-lg text-muted italic font-serif leading-relaxed border-l-2 border-primary/20 pl-6"
        >
          "Building intelligent physical systems that scale."
        </p>
      </div>
      <div class="lg:col-span-7 space-y-6">
        {
          siteConfig.about.map((paragraph) => (
            <p class="text-[16px] leading-[1.8] text-text/80">{paragraph}</p>
          ))
        }
      </div>
    </div>
  </Section>

  <Section id="domains" class="bg-background">
    <div class="mb-12">
      <span
        class="text-[10px] font-mono uppercase tracking-[0.3em] text-primary mb-3 block"
        >02 — Expertise</span
      >
      <h2 class="text-4xl md:text-5xl font-serif italic text-heading">
        Core Domains
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-1">
      {
        siteConfig.domains.map((domain, i) => (
          <div class="group relative p-8 border border-border/10 hover:border-primary/20 transition-all duration-500 hover:bg-surface/30">
            <span class="text-[64px] font-serif italic text-heading/5 absolute top-4 right-6 select-none group-hover:text-primary/10 transition-colors duration-500">
              {String(i + 1).padStart(2, "0")}
            </span>
            <h3 class="text-xl font-serif text-heading mb-6 relative z-10 group-hover:text-primary transition-colors duration-300">
              {domain.title}
            </h3>
            <ul class="space-y-2 relative z-10">
              {domain.items.map((item) => (
                <li class="text-sm text-muted/70 group-hover:text-muted transition-colors duration-300 flex items-start">
                  <span class="text-primary/30 mr-3 mt-1.5 group-hover:text-primary/60 transition-colors">
                    —
                  </span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </Section>

  <Section id="projects" class="bg-surface">
    <div class="mb-12">
      <span
        class="text-[10px] font-mono uppercase tracking-[0.3em] text-primary mb-3 block"
        >03 — Work</span
      >
      <h2 class="text-4xl md:text-5xl font-serif italic text-heading">
        Featured Projects
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
    <div class="mt-16 text-center">
      <a
        href="/projects"
        class="inline-flex items-center px-10 py-4 text-sm font-mono uppercase tracking-[0.2em] text-background bg-heading hover:bg-primary hover:text-white rounded-full transition-all duration-500 shadow-xl hover:shadow-primary/20 group"
      >
        All Projects
        <svg
          class="ml-3 w-4 h-4 transform group-hover:translate-x-1 transition-transform"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </Section>

  <Section id="skills" class="bg-background">
    <div class="mb-12">
      <span
        class="text-[10px] font-mono uppercase tracking-[0.3em] text-primary mb-3 block"
        >04 — Tools</span
      >
      <h2 class="text-4xl md:text-5xl font-serif italic text-heading">
        Skills & Toolchain
      </h2>
    </div>
    <SkillMatrix />
  </Section>

  <Section id="leadership" class="bg-surface">
    <div class="mb-12">
      <span
        class="text-[10px] font-mono uppercase tracking-[0.3em] text-primary mb-3 block"
        >05 — Leadership</span
      >
      <h2 class="text-4xl md:text-5xl font-serif italic text-heading">
        Experience & Impact
      </h2>
    </div>
    <div class="space-y-16">
      {
        siteConfig.experience.slice(0, 2).map((company) => (
          <div>
            <div class="flex items-center gap-4 mb-8">
              <div class="w-10 h-10 rounded-xl bg-surface border border-primary/20 flex items-center justify-center text-primary font-serif font-bold italic shadow-sm">
                {company.org.charAt(0)}
              </div>
              <h3 class="text-2xl font-serif italic text-heading">
                {company.org}
              </h3>
            </div>

            <div class="space-y-12 relative border-l border-surface/50 ml-5 pl-10">
              {company.roles.map((role) => (
                <div class="relative group">
                  <div class="absolute -left-[46px] top-2 w-3 h-3 bg-background border-2 border-primary rounded-sm transition-transform duration-300 group-hover:rotate-45 group-hover:bg-primary/20" />
                  <div class="mb-4">
                    <div class="flex items-center gap-3 mb-1">
                      <span class="text-[9px] font-mono uppercase tracking-widest text-primary/60">
                        {role.category}
                      </span>
                      <span class="w-1 h-1 rounded-full bg-border" />
                      <span class="text-[10px] font-mono text-muted uppercase tracking-tighter">
                        {role.date}
                      </span>
                    </div>
                    <h4 class="text-xl font-serif text-text">{role.title}</h4>
                  </div>
                  <ul class="space-y-3">
                    {role.details.slice(0, 2).map((detail) => (
                      <li class="flex items-start text-sm text-muted/80 group-hover:text-muted transition-colors">
                        <span class="text-primary/30 mr-4 mt-1.5 group-hover:text-primary/60 transition-colors">
                          —
                        </span>
                        <span class="leading-relaxed">{detail}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
    <div class="mt-20 text-center">
      <a
        href="/experience"
        class="inline-flex items-center px-10 py-4 text-sm font-mono uppercase tracking-[0.2em] rounded-full text-background bg-heading hover:bg-primary hover:text-white transition-all duration-500 shadow-xl hover:shadow-primary/20 group"
      >
        View Full Journey
        <svg
          class="ml-3 w-4 h-4 transform group-hover:translate-x-1 transition-transform"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </Section>

  <Section id="contact" class="bg-background">
    <div class="max-w-3xl mx-auto text-center">
      <span
        class="text-[10px] font-mono uppercase tracking-[0.3em] text-primary mb-3 block"
        >06 — Contact</span
      >
      <h2 class="text-4xl md:text-5xl font-serif italic text-heading mb-6">
        Let's Connect
      </h2>
      <p class="text-text/70 mb-12 text-lg leading-relaxed max-w-xl mx-auto">
        Whether you have a question or just want to say hi, I'll try my best to
        get back to you!
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a
          href={siteConfig.profile.social.email}
          class="inline-flex items-center justify-center px-8 py-4 text-sm font-mono uppercase tracking-widest bg-surface hover:bg-surface/80 text-heading rounded-full border border-border/30 hover:border-primary/30 transition-all duration-500 group"
        >
          <svg
            class="w-5 h-5 mr-3 group-hover:text-primary transition-colors"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
          Say Hello
        </a>
        <a
          href={siteConfig.profile.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-8 py-4 text-sm font-mono uppercase tracking-widest bg-primary/10 hover:bg-primary text-primary hover:text-white rounded-full border border-primary/20 transition-all duration-500 group"
        >
          <svg class="w-5 h-5 mr-3" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
            ></path>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
  </Section>
</Layout>
