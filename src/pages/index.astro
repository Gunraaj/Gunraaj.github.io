---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SkillMatrix from '../components/SkillMatrix.astro';
import { siteConfig } from '../content/site';

const featuredProjects = siteConfig.projects.filter(p => p.featured && p.enabled);
---

<Layout title="Home">
  <Hero />

  <Section id="about" title="About Me" class="bg-surface">
    <div class="prose prose-invert max-w-none text-text space-y-4">
      {siteConfig.about.map((paragraph) => (
        <p class="leading-relaxed">{paragraph}</p>
      ))}
    </div>
  </Section>

  <Section id="domains" title="Core Electrical Domains" class="bg-background">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {siteConfig.domains.map((domain) => (
        <div class="bg-surface p-6 rounded-lg border border-border hover:border-primary transition-all group">
          <h3 class="text-xl font-semibold text-heading mb-4 group-hover:text-primary transition-colors">
            {domain.title}
          </h3>
          <ul class="space-y-2">
            {domain.items.map((item) => (
              <li class="text-muted text-sm flex items-start">
                <span class="text-primary mr-2 mt-1">›</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </Section>

  <Section id="projects" title="Featured Projects" class="bg-surface">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {featuredProjects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
    <div class="mt-12 text-center">
      <a
        href="/projects"
        class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-primary hover:bg-blue-700 transition-colors"
      >
        View All Projects
        <svg class="ml-2 -mr-1 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </Section>

  <Section id="skills" title="Skills & Toolchain" class="bg-background">
    <SkillMatrix />
  </Section>

  <Section id="leadership" title="Leadership & Organization" class="bg-surface">
    <div class="space-y-8">
      {siteConfig.experience.map((exp) => (
        <div class="bg-background p-8 rounded-xl border border-border">
          <div class="flex flex-col md:flex-row md:items-center justify-between mb-6">
            <div>
              <h3 class="text-2xl font-bold text-heading">{exp.role}</h3>
              <p class="text-primary text-lg">{exp.org}</p>
            </div>
            <span class="mt-2 md:mt-0 px-4 py-1 bg-surface text-text rounded-full text-sm border border-border">
              {exp.date}
            </span>
          </div>
          <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {exp.details.map((detail) => (
              <li class="flex items-start text-text">
                <svg class="w-5 h-5 text-accent mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>{detail}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </Section>

  <Section id="contact" title="Get In Touch" class="bg-background">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-text mb-8 text-lg">
        Whether you have a question or just want to say hi, I'll try my best to get back to you!
      </p>
      <div class="flex justify-center gap-6">
        <a
          href={siteConfig.profile.social.email}
          class="flex items-center px-8 py-4 bg-surface hover:bg-surface/80 text-heading rounded-lg border border-border transition-all hover:-translate-y-1"
        >
          <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Say Hello
        </a>
        <a
          href={siteConfig.profile.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center px-8 py-4 bg-primary hover:bg-blue-600 text-white rounded-lg transition-all hover:-translate-y-1"
        >
          <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
  </Section>
</Layout>
