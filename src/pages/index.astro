---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SkillMatrix from "../components/SkillMatrix.astro";
import ResumeSection from "../components/ResumeSection.astro";
import EthicsSection from "../components/EthicsSection.astro";
import SwotAnalysis from "../components/SwotAnalysis.astro";
import LeadershipSection from "../components/LeadershipSection.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import FutureRoadmap from "../components/FutureRoadmap.astro";
import { siteConfig } from "../content/site";
---

<Layout title="Portfolio" showPreloader={true}>
  <!-- ═══ HERO ═══ -->
  <Hero />

  <!-- Submission Bar -->
  <div class="border-y border-border/40 py-2.5 bg-surface/20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-1 text-xs font-mono text-muted">
      <span>{siteConfig.profile.program}</span>
      <span class="w-1 h-1 rounded-full bg-primary/30 hidden sm:block"></span>
      <span>{siteConfig.profile.institution}</span>
      <span class="w-1 h-1 rounded-full bg-primary/30 hidden sm:block"></span>
      <span>Submitted: {siteConfig.profile.submissionDate}</span>
    </div>
  </div>

  <!-- ═══ TABLE OF CONTENTS — Compact strip ═══ -->
  <section id="toc" class="py-10 border-b border-border/30">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center justify-center gap-2">
        {[
          { num: "01", label: "Philosophy", href: "#philosophy" },
          { num: "02", label: "Resume", href: "#resume" },
          { num: "03", label: "Projects", href: "#projects" },
          { num: "04", label: "Skills", href: "#skills" },
          { num: "05", label: "Leadership", href: "#leadership" },
          { num: "06", label: "Ethics", href: "#ethics" },
          { num: "07", label: "Future", href: "#future" },
          { num: "08", label: "Reflection", href: "#conclusion" },
          { num: "09", label: "Testimonials", href: "#testimonials" },
        ].map((item) => (
          <a href={item.href} class="group px-3 py-1.5 rounded-full text-xs font-medium text-muted hover:text-primary hover:bg-primary/5 transition-all">
            <span class="text-primary/30 group-hover:text-primary/60 font-mono mr-1">{item.num}</span>{item.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- PHILOSOPHY — Asymmetric layout with big quote block    -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section id="philosophy" class="py-20 relative overflow-hidden">
    <span class="big-number">01</span>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="scroll-reveal mb-10">
        <span class="section-label">Introduction</span>
        <h2 class="section-title">Learning Philosophy</h2>
      </div>

      <!-- Journey — first paragraph large, rest normal -->
      <div class="scroll-reveal mb-12">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-start">
          <!-- Main text — takes 3 cols -->
          <div class="lg:col-span-3 space-y-4">
            {siteConfig.learningPhilosophy.journey.map((paragraph, i) => (
              <p class:list={["leading-relaxed", i === 0 ? "text-lg text-heading font-medium" : "text-text/80 text-sm"]}>
                {paragraph}
              </p>
            ))}
          </div>
          <!-- Core Values — takes 2 cols, offset -->
          <div class="lg:col-span-2 space-y-3 stagger-fade">
            {siteConfig.learningPhilosophy.coreValues.map((value) => (
              <div class="glass-card p-4 group">
                <div class="flex items-center gap-2 mb-1.5">
                  <span class="text-lg">{value.icon}</span>
                  <h4 class="text-xs font-semibold text-heading group-hover:text-primary transition-colors uppercase tracking-wide">{value.title}</h4>
                </div>
                <p class="text-xs text-muted leading-relaxed">{value.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Academic Philosophy — Quote block -->
      <div class="scroll-reveal">
        <div class="quote-block">
          <div class="flex flex-col gap-5">
            <div class="pb-5 border-b border-border/30">
              <p class="text-xl md:text-2xl font-display text-primary mb-1.5 font-medium tracking-wide">ਮਨਿ ਜੀਤੈ ਜਗੁ ਜੀਤੁ</p>
              <p class="text-sm text-text/70 italic mb-3">Conquer your mind, and you conquer the world</p>
              <p class="text-[10px] text-muted font-mono uppercase tracking-widest">— Sri Guru Granth Sahib Ji</p>
            </div>
            <p class="text-base text-heading/80 leading-relaxed">
              {siteConfig.learningPhilosophy.academicPhilosophy}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- RESUME — Full width bento treatment                    -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section id="resume" class="py-20 section-alt relative overflow-hidden">
    <span class="big-number" style="left: auto; right: -1rem;">02</span>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="scroll-reveal mb-12">
        <span class="section-label">Resume</span>
        <h2 class="section-title">Curriculum Vitae</h2>
        <p class="section-subtitle">Academic background, work experience, certifications, and engagement.</p>
      </div>
      <div class="scroll-reveal">
        <ResumeSection />
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- PROJECTS — Feature first project large, rest grid      -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section id="projects" class="py-20 relative overflow-hidden">
    <span class="big-number">03</span>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="scroll-reveal flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-12">
        <div>
          <span class="section-label">Projects</span>
          <h2 class="section-title">Research & Projects</h2>
        </div>
        <p class="text-sm text-muted max-w-sm">Interdisciplinary case studies with methodology, results, and working code.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {siteConfig.projects.filter(p => p.enabled).map((project) => (
          <div class="scroll-reveal">
            <ProjectCard project={project} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- SKILLS — Bento grid with mixed card sizes               -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section id="skills" class="py-20 section-alt relative overflow-hidden">
    <span class="big-number" style="left: auto; right: -1rem;">04</span>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="scroll-reveal mb-12">
        <span class="section-label">Skills</span>
        <h2 class="section-title">Skill Development</h2>
        <p class="section-subtitle">Technical proficiencies, soft skills, and creative abilities — each with evidence.</p>
      </div>

      <div class="scroll-reveal">
        <SkillMatrix />
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- LEADERSHIP — Left-aligned header, timeline right        -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section id="leadership" class="py-20 relative overflow-hidden">
    <span class="big-number">05</span>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="scroll-reveal mb-12">
        <span class="section-label">Leadership</span>
        <h2 class="section-title">Leadership & Collaboration</h2>
        <p class="section-subtitle">Team dynamics, conflict resolution, and cross-functional leadership.</p>
      </div>

      <!-- Extracted unique high-fidelity UI component -->
      <div class="scroll-reveal">
        <LeadershipSection />
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- ETHICS — Full width with colored cards                  -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section id="ethics" class="py-20 section-alt relative overflow-hidden">
    <span class="big-number" style="left: auto; right: -1rem;">06</span>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="scroll-reveal flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-12">
        <div>
          <span class="section-label">Ethics</span>
          <h2 class="section-title">Global Awareness & Ethics</h2>
        </div>
        <p class="text-sm text-muted max-w-xs">Ethical dimensions in engineering — data privacy, AI bias, sustainability.</p>
      </div>
      <EthicsSection />
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- FUTURE — Horizontal timeline + bento grid                -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section id="future" class="py-20 relative overflow-hidden">
    <span class="big-number">07</span>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="scroll-reveal mb-12">
        <span class="section-label">Future</span>
        <h2 class="section-title">Future Aspirations</h2>
        <p class="section-subtitle">A roadmap for growth — short-term goals to long-term engineering vision.</p>
      </div>
      <div class="scroll-reveal">
        <FutureRoadmap />
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- CONCLUSION & SWOT — Split layout                        -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section id="conclusion" class="py-20 section-alt relative overflow-hidden">
    <span class="big-number" style="left: auto; right: -1rem;">08</span>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="scroll-reveal mb-12">
        <span class="section-label">Conclusion</span>
        <h2 class="section-title">Self-Assessment & Reflection</h2>
      </div>

      <!-- Summary — no italic -->
      <div class="scroll-reveal mb-12">
        <div class="space-y-3">
          {siteConfig.conclusion.summary.map((paragraph, i) => (
            <p class:list={["leading-relaxed", i === 0 ? "text-lg text-heading font-medium" : "text-sm text-text/80"]}>
              {paragraph}
            </p>
          ))}
        </div>
      </div>

      <!-- Lessons + Growth — asymmetric 3/2 -->
      <div class="scroll-reveal grid grid-cols-1 lg:grid-cols-5 gap-5 mb-12">
        <div class="lg:col-span-3 glass-card p-5">
          <h3 class="text-base font-semibold text-heading mb-3 flex items-center gap-2">
            <span class="text-primary">📖</span> Lessons Learned
          </h3>
          <ul class="space-y-2">
            {siteConfig.conclusion.lessonsLearned.map((lesson) => (
              <li class="flex items-start gap-2 text-sm text-text/80">
                <span class="text-primary/50 mt-0.5 text-xs">▸</span>
                <span>{lesson}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="lg:col-span-2 glass-card p-5">
          <h3 class="text-base font-semibold text-heading mb-3 flex items-center gap-2">
            <span class="text-accent">📈</span> Growth Areas
          </h3>
          <ul class="space-y-2">
            {siteConfig.conclusion.growthAreas.map((area) => (
              <li class="flex items-start gap-2 text-sm text-text/80">
                <span class="text-accent/50 mt-0.5 text-xs">▸</span>
                <span>{area}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Self-Evaluation — Quote block -->
      <div class="scroll-reveal mb-14">
        <div class="quote-block">
          <h3 class="text-sm font-mono uppercase tracking-wider text-primary/60 mb-2">Self-Evaluation</h3>
          <p class="text-base text-heading/80 leading-relaxed">
            {siteConfig.conclusion.selfEvaluation}
          </p>
        </div>
      </div>

      <!-- SWOT -->
      <div class="scroll-reveal">
        <h3 class="text-xl font-display font-semibold text-heading mb-6 text-center">SWOT Analysis</h3>
        <SwotAnalysis />
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══ TESTIMONIALS ═══ -->
  <section id="testimonials" class="py-20 relative overflow-hidden">
    <span class="big-number">09</span>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="scroll-reveal text-center mb-12">
        <span class="section-label">Testimonials</span>
        <h2 class="section-title">Recommendations</h2>
        <p class="section-subtitle mx-auto">What mentors, faculty, and peers say about working with me.</p>
      </div>
      <TestimonialCard />
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══ CTA ═══ -->
  <section class="py-20 section-alt">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="scroll-reveal">
        <h2 class="section-title mb-4">Let's <span class="gradient-text">Connect</span></h2>
        <p class="text-sm text-muted mb-8 max-w-md mx-auto">Interested in collaboration, research, or just want to chat about engineering?</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href={siteConfig.profile.social.email} class="group px-6 py-3 bg-primary text-white hover:bg-primary/90 font-semibold rounded-lg transition-all hover:-translate-y-0.5 shadow-lg shadow-primary/20 flex items-center gap-2">
            Send Email
            <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </a>
          <a href={siteConfig.profile.social.linkedin} target="_blank" rel="noopener noreferrer" class="px-6 py-3 bg-surface border border-border text-heading font-semibold rounded-lg transition-all hover:-translate-y-0.5 hover:border-primary/30">
            LinkedIn
          </a>
          <a href={siteConfig.profile.social.github} target="_blank" rel="noopener noreferrer" class="px-6 py-3 bg-surface border border-border text-heading font-semibold rounded-lg transition-all hover:-translate-y-0.5 hover:border-primary/30">
            GitHub
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FOOTER ═══ -->
  <footer class="py-6 border-t border-border/40">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-muted">
      <p>© {new Date().getFullYear()} {siteConfig.profile.name}</p>
      <div class="flex items-center gap-4">
        <a href={siteConfig.profile.social.github} target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">GitHub</a>
        <a href={siteConfig.profile.social.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">LinkedIn</a>
        <a href={siteConfig.profile.social.email} class="hover:text-primary transition-colors">Email</a>
      </div>
    </div>
  </footer>
</Layout>
