---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import { siteConfig } from "../content/site";
---

<Layout title="Experience">
  <Section title="Experience & Leadership" class="pt-24 min-h-screen">
    <div class="max-w-5xl mx-auto py-12">
      <div class="space-y-32">
        {
          siteConfig.experience.map((company) => (
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 relative">
              {/* Sidebar metadata for Company */}
              <div class="lg:col-span-3">
                <div class="sticky top-32">
                  <div class="flex items-center gap-3 mb-4">
                    <div class="w-8 h-8 rounded-lg bg-primary/10 border border-primary/20 flex items-center justify-center text-primary font-mono text-xs">
                      {company.org.charAt(0)}
                    </div>
                    <span class="text-xs font-mono uppercase tracking-[0.2em] text-muted">
                      {company.location}
                    </span>
                  </div>
                  <h2 class="text-3xl font-serif italic text-heading leading-tight pr-4">
                    {company.org}
                  </h2>
                </div>
              </div>

              {/* Roles Timeline */}
              <div class="lg:col-span-9 relative border-l border-border/40 ml-4 lg:ml-0 pl-10 lg:pl-16 space-y-24">
                {company.roles.map((role) => (
                  <div class="relative group">
                    {/* Hollow Square Marker */}
                    <div class="absolute -left-[51px] lg:-left-[75px] top-2 w-5 h-5 bg-background border-2 border-primary rounded-sm transition-transform group-hover:rotate-45 group-hover:bg-primary/20 duration-300 shadow-[0_0_15px_rgba(var(--color-primary)/0.3)]" />

                    {/* Metadata Header */}
                    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-4">
                      <span class="text-[10px] font-mono uppercase tracking-[0.3em] text-primary bg-primary/5 px-2 py-1 rounded border border-primary/10 select-none">
                        {role.category}
                      </span>
                      <span class="text-xs font-mono text-muted/60 tracking-widest uppercase">
                        {role.date}
                      </span>
                    </div>

                    <h3 class="text-3xl md:text-4xl font-serif text-heading group-hover:text-primary transition-colors duration-500 mb-8 max-w-2xl">
                      {role.title}
                    </h3>

                    <div class="space-y-6 max-w-3xl">
                      {role.details.map((detail) => (
                        <div class="flex items-start group/detail">
                          <span class="text-primary mr-6 mt-3 opacity-40 group-hover/detail:opacity-100 transition-all duration-300 select-none">
                            <svg
                              width="24"
                              height="1"
                              viewBox="0 0 24 1"
                              fill="none"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <line
                                x1="0"
                                y1="0.5"
                                x2="24"
                                y2="0.5"
                                stroke="currentColor"
                                stroke-width="2"
                              />
                            </svg>
                          </span>
                          <p class="text-[17px] leading-[1.7] text-muted group-hover/detail:text-text transition-colors duration-300">
                            {detail}
                          </p>
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </Section>
</Layout>
